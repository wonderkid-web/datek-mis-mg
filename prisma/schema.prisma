model PcSpecs {
  assetId                 Int                          @id
  processorOptionId       Int?
  ramOptionId             Int?
  storageTypeOptionId     Int?
  licenseOptionId         Int?
  licenseKey              String?                      @map("license_key") @db.VarChar(30)
  osOptionId              Int?
  powerOptionId           Int?
  microsoftOfficeOptionId Int?
  colorOptionId           Int?
  graphicOptionId         Int?
  monitorOptionId         Int?
  motherboardOptionId     Int?
  upsOptionId             Int?
  macLan                  String?                      @unique @map("mac_lan") @db.VarChar(17)
  casing                  String?                      @db.VarChar(100)
  asset                   Asset                        @relation(fields: [assetId], references: [id])
  colorOption             LaptopColorOption?          @relation(fields: [colorOptionId], references: [id])
  graphicOption           LaptopGraphicOption?        @relation(fields: [graphicOptionId], references: [id])
  licenseOption           LaptopLicenseOption?        @relation(fields: [licenseOptionId], references: [id])
  microsoftOfficeOption   LaptopMicrosoftOfficeOption? @relation(fields: [microsoftOfficeOptionId], references: [id])
  monitorOption           PcMonitorOption?            @relation(fields: [monitorOptionId], references: [id])
  motherboardOption       PcMotherboardOption?        @relation(fields: [motherboardOptionId], references: [id])
  osOption                LaptopOsOption?             @relation(fields: [osOptionId], references: [id])
  powerOption             LaptopPowerOption?          @relation(fields: [powerOptionId], references: [id])
  processorOption         LaptopProcessorOption?      @relation(fields: [processorOptionId], references: [id])
  ramOption               LaptopRamOption?            @relation(fields: [ramOptionId], references: [id])
  storageTypeOption       LaptopStorageTypeOption?    @relation(fields: [storageTypeOptionId], references: [id])
  upsOption               PcUpsOption?                @relation(fields: [upsOptionId], references: [id])

  @@index([colorOptionId], map: "pc_specs_colorOptionId_fkey")
  @@index([graphicOptionId], map: "pc_specs_graphicOptionId_fkey")
  @@index([licenseOptionId], map: "pc_specs_licenseOptionId_fkey")
  @@index([microsoftOfficeOptionId], map: "pc_specs_microsoftOfficeOptionId_fkey")
  @@index([monitorOptionId], map: "pc_specs_monitorOptionId_fkey")
  @@index([motherboardOptionId], map: "pc_specs_motherboardOptionId_fkey")
  @@index([osOptionId], map: "pc_specs_osOptionId_fkey")
  @@index([powerOptionId], map: "pc_specs_powerOptionId_fkey")
  @@index([processorOptionId], map: "pc_specs_processorOptionId_fkey")
  @@index([ramOptionId], map: "pc_specs_ramOptionId_fkey")
  @@index([storageTypeOptionId], map: "pc_specs_storageTypeOptionId_fkey")
  @@index([upsOptionId], map: "pc_specs_upsOptionId_fkey")
  @@map("pc_specs")
}

