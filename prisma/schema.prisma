model CctvSpecs {
  assetId         Int                @id
  sbu             String
  viewCamera      String
  systemVersion   String?
  power           String?
  ipAddress       String             @unique
  macAddress      String?            @unique
  username        String?
  password        String?
  brandId         Int?
  modelId         Int?
  deviceTypeId    Int?
  channelCameraId Int?               @unique
  asset           Asset              @relation(fields: [assetId], references: [id], onDelete: Cascade)
  brand           CctvBrand?         @relation(fields: [brandId], references: [id])
  model           CctvModel?         @relation(fields: [modelId], references: [id])
  deviceType      CctvDeviceType?    @relation(fields: [deviceTypeId], references: [id])
  channelCamera   CctvChannelCamera? @relation(fields: [channelCameraId], references: [id])

  @@index([brandId])
  @@index([modelId])
  @@index([deviceTypeId])
  @@index([channelCameraId])
  @@map("cctv_specs")
}

// New model for IP Address management
model IpAddress {
  id                Int              @id @default(autoincrement())
  userId            Int
  ip                String           @unique @map("ip_address") @db.VarChar(15)
  connection        IPConnectionType
  status            IPStatus
  role              IPRole
  company           String           @db.VarChar(255)
  assetAssignmentId Int?
  macWlan           String?          @default("0.0.0.0.0.0") @map("mac_wlan") @db.VarChar(17)
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  user            User             @relation(fields: [userId], references: [id])
  assetAssignment AssetAssignment? @relation(fields: [assetAssignmentId], references: [id])

  @@index([userId], map: "ip_addresses_userId_fkey")
  @@index([assetAssignmentId], map: "ip_addresses_assetAssignmentId_fkey")
  @@map("ip_addresses")
}

model CctvRepetitiveMaintenance {
  id              Int        @id @default(autoincrement())
  periode         DateTime
  perusahaan      String     @db.VarChar(255)
  channelCameraId Int?
  status          CCTVStatus

  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  channelCamera CctvChannelCamera? @relation(fields: [channelCameraId], references: [id], onDelete: SetNull)

  @@index([channelCameraId])
  @@map("cctv_repetitive_maintenances")
}

model Isp {
  id             Int         @id @default(autoincrement())
  // sbu            String      @db.VarChar(255)
  isp            String      @db.VarChar(255)
  asNumber       String      @map("as_number") @db.VarChar(255)
  address        String      @db.VarChar(255)
  maps           String      @db.VarChar(255)
  pop            String      @db.VarChar(255)
  transmisi      String      @db.VarChar(255)
  productService String      @map("product_service") @db.VarChar(255)
  ipPublic       String      @map("ip_public") @db.VarChar(255)
  sla            String      @db.VarChar(255)
  picNoc         String      @map("pic_noc") @db.VarChar(255)
  hpNoc          String      @map("hp_noc") @db.VarChar(255)
  prtg           String      @db.VarChar(255)
  username       String      @db.VarChar(255)
  password       String      @db.VarChar(255)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  ispReports     IspReport[]
  problemSequences ProblemSequence[]

  @@map("isps")
}

model IspReport {
  id            Int           @id @default(autoincrement())
  reportDate    DateTime
  sbu           String        @db.VarChar(255)
  ispId         Int
  bandwidth     BandwidthType
  downloadSpeed Float
  uploadSpeed   Float
  link          String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  isp           Isp           @relation(fields: [ispId], references: [id])

  @@index([ispId])
  @@map("isp_reports")
}

model ProblemSequence {
  id           Int      @id @default(autoincrement())
  ticketNumber String   @unique @map("ticket_number") @db.VarChar(30)
  sbu          String   @db.VarChar(255)
  ispId        Int
  pic          String   @db.VarChar(255)
  dateDown     DateTime @map("date_down")
  dateDoneUp   DateTime @map("date_done_up")
  issue        String   @db.Text
  trouble      String   @db.Text
  solved       String   @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  isp Isp @relation(fields: [ispId], references: [id])

  @@index([ispId])
  @@map("problem_sequences")
}

model BilingRecord {
  id        Int      @id @default(autoincrement())
  callDate  DateTime @map("call_date")
  userId    Int
  extension Int
  dial      String   @db.VarChar(255)
  duration  String   @db.VarChar(20)
  trunk     Int
  pstn      Int
  cost      Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("biling_records")
}

model SparepartMovement {
  id                  Int                         @id @default(autoincrement())
  deviceFamily        SparepartDeviceFamily       @map("device_family")
  partType            SparepartPartType           @map("part_type")
  sourceOptionId      Int                         @map("source_option_id")
  sourceOptionValue   String                      @map("source_option_value") @db.VarChar(255)
  movementType        SparepartMovementType       @map("movement_type")
  adjustmentDirection SparepartAdjustmentDirection? @map("adjustment_direction")
  quantity            Int
  movedAt             DateTime                    @map("moved_at")
  userId              Int?                        @map("user_id")
  notes               String?                     @db.Text
  createdAt           DateTime                    @default(now()) @map("created_at")
  updatedAt           DateTime                    @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([deviceFamily, partType, sourceOptionId], map: "sparepart_movements_item_lookup_idx")
  @@index([movedAt], map: "sparepart_movements_moved_at_idx")
  @@index([movementType], map: "sparepart_movements_movement_type_idx")
  @@index([userId], map: "sparepart_movements_userId_fkey")
  @@map("sparepart_movements")
}

model CallOutgoingOption {
  id            Int            @id @default(autoincrement())
  value         Int            @unique
  line          Int
  company       String         @db.VarChar(255)
  phoneAccounts PhoneAccount[]

  @@map("call_outgoing_options")
}

model Trunk {
  id        Int    @id @default(autoincrement())
  nomorLine Int    @unique @map("nomor_line")
  company   String @db.VarChar(255)
  extension Int

  @@map("trunks")
}

model Pstn {
  id       Int    @id @default(autoincrement())
  pstnCode Int    @unique @map("pstn_code")
  pstnName String @map("pstn_name") @db.VarChar(255)

  @@map("pstns")
}

model PhoneAccount {
  id             Int      @id @default(autoincrement())
  userId         Int
  extension      Int
  account        Int
  codeDial       String   @map("code_dial") @db.VarChar(255)
  deposit        Decimal  @db.Decimal(12, 2)
  callOutgoingId Int      @map("call_outgoing_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user               User               @relation(fields: [userId], references: [id])
  callOutgoingOption CallOutgoingOption @relation(fields: [callOutgoingId], references: [id])

  @@index([userId])
  @@index([callOutgoingId])
  @@map("phone_accounts")
}
